# Local development settings.

# SQLite database path. Relative paths are resolved from the project root.
DB_PATH=data/learnkeeper.sqlite3

# Telegram bot settings.
TELEGRAM_BOT_TOKEN=
TG_USER_ID=

# Optional MTProto settings for sending .md materials with explicit
# text/markdown metadata. Create API_ID/API_HASH at https://my.telegram.org.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_MTPROTO_SESSION=data/telegram-mtproto

REVIEW_TICK_SECONDS=60
QUIZ_QUESTION_COUNT=5
DAILY_QUIZ_TIME=10:20
DAILY_QUIZ_TIMEZONE=Europe/Moscow

# Daily coding-practice reminder. Off by default (toggle in Telegram settings).
# Static list of small exercises, no LLM call, reuses DAILY_QUIZ_TIMEZONE.
CODING_REPS_TIME=19:30

# Quiz generation.
# Use "fake" for local no-LLM testing or "claude_cli" for Claude Code via subscription OAuth.
LLM_PROVIDER=fake
CLAUDE_BIN=claude
CLAUDE_CODE_OAUTH_TOKEN=
# Pin the model explicitly so usage is predictable (empty = Claude Code default).
# quiz + mistake review use this; keep it on Sonnet.
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_TIMEOUT_SECONDS=600
ALLOW_PAID_API=false

# Local usage budgets. These are LOCAL benchmarks shown in the Telegram usage
# report, NOT real Anthropic limits. Token budgets drive the token % line.
LLM_INPUT_USD_PER_1M_TOKENS=2
LLM_OUTPUT_USD_PER_1M_TOKENS=10
LLM_USAGE_BUDGET_5H_USD=6.5
LLM_USAGE_BUDGET_DAILY_USD=13
LLM_USAGE_BUDGET_WEEKLY_USD=65
LLM_USAGE_BUDGET_MONTHLY_USD=250
LLM_USAGE_BUDGET_5H_TOKENS=1000000
LLM_USAGE_BUDGET_DAILY_TOKENS=2500000
LLM_USAGE_BUDGET_WEEKLY_TOKENS=12000000
LLM_USAGE_BUDGET_MONTHLY_TOKENS=45000000

# Voice input / speech-to-text.
# Default is disabled, so voice messages do not call any paid APIs accidentally.
STT_PROVIDER=disabled
VOICE_DIR=data/voice
STT_LANGUAGE=ru
STT_PROMPT=Go, Golang, goroutine, mutex, channel, context, runtime, слайсы, мапы
STT_TIMEOUT_SECONDS=180

# Local no-API option: whisper.cpp executable + GGML model.
# Run scripts/setup-whisper-cpp.ps1 or set these paths manually.
STT_WHISPER_CPP_BIN=tools/whisper.cpp/bin/whisper-cli.exe
STT_WHISPER_CPP_MODEL=tools/whisper.cpp/models/ggml-base.bin

# Alternative local no-API option if you install the Python/OpenAI Whisper CLI separately.
STT_WHISPER_BIN=whisper
STT_WHISPER_MODEL=small

# Optional paid OpenAI STT option.
OPENAI_API_KEY=
STT_OPENAI_MODEL=gpt-4o-transcribe
FFMPEG_BIN=ffmpeg

# lk-prep git sync.
REPO_GIT_REMOTE=origin
REPO_GIT_BRANCH=

# Fast-forward the lk-prep clone before reading topics and before quiz
# generation, so menus and tests reflect the newest materials. Enable on VPS
# where lk-prep is a git clone with an upstream branch. Best-effort: a
# failed pull is logged and never blocks bot commands.
REPO_PULL_BEFORE_READ=false
REPO_PULL_BEFORE_QUIZ=false
REPO_PULL_TIMEOUT_SECONDS=120

# "Читать материал" sends GitHub links instead of files, since Telegram's
# Bot API does not preserve a usable MIME type for uploaded documents. Base
# URL a topic's material path is appended to (no trailing slash).
MATERIALS_GITHUB_BASE_URL=https://github.com/Nuagrinn/lk-prep/blob/main

# Lightweight agent for Telegram topic inbox.
# This does not inspect or modify lk-prep; it only rewrites a rough
# voice/text idea into a clean title and optional block. It is a trivial task,
# so a cheaper/faster model (Haiku) is enough.
TOPIC_INBOX_AGENT_PROVIDER=fake
TOPIC_INBOX_AGENT_MODEL=claude-haiku-4-5
TOPIC_INBOX_AGENT_TIMEOUT_SECONDS=120

# Agent for full mistake reports after failed quiz answers.
# It does not write to lk-prep; it only returns a structured report
# that can be saved to SQLite.
MISTAKE_REVIEW_AGENT_PROVIDER=fake
MISTAKE_REVIEW_AGENT_MODEL=
MISTAKE_REVIEW_AGENT_TIMEOUT_SECONDS=180

# Agent that checks a self-explanation (voice/text) against a topic's material.
# It does not write to lk-prep; the check is saved to its own SQLite
# table (explanation_checks), independent from the mistake-work reports table.
EXPLAIN_CHECK_AGENT_PROVIDER=fake
EXPLAIN_CHECK_AGENT_MODEL=
EXPLAIN_CHECK_AGENT_TIMEOUT_SECONDS=180

# Optional local path to your lk-prep repository.
# Example:
# LK_PREP_PATH=C:\Users\Vladislav\Desktop\lk-prep
LK_PREP_PATH=
